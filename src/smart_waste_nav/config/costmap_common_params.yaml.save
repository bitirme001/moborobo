sensor_frame: rslidarsensor_frame: rslidarobstacle_range: 3.0
raytrace_range: 3.5

footprint: [[0.25, 0.20], [0.25, -0.20], [-0.25, -0.20], [-0.25, 0.20]]

observation_sources: laser_scan_sensor

