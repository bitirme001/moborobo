<launch>

  <node pkg="move_base"
        type="move_base"
        name="move_base"
        output="screen">

    <param name="base_global_planner" value="navfn/NavfnROS"/>
    <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS"/>
    <param name="controller_frequency" value="8.0"/>
    <param name="planner_frequency" value="1.0"/>
    <param name="controller_patience" value="4.0"/>
    <param name="planner_patience" value="3.0"/>
    <param name="oscillation_timeout" value="8.0"/>
    <param name="oscillation_distance" value="0.20"/>
    <param name="recovery_behavior_enabled" value="true"/>
    <param name="clearing_rotation_allowed" value="true"/>

    <rosparam file="$(find smart_waste_nav)/config/costmap_common_params.yaml"
              command="load"
              ns="global_costmap"/>

    <rosparam file="$(find smart_waste_nav)/config/costmap_common_params.yaml"
              command="load"
              ns="local_costmap"/>

    <rosparam file="$(find smart_waste_nav)/config/global_costmap_params.yaml"
              command="load"/>

    <rosparam file="$(find smart_waste_nav)/config/local_costmap_params.yaml"
              command="load"/>

    <rosparam file="$(find smart_waste_nav)/config/trajectory_planner.yaml"
              command="load"/>

  </node>

</launch>
